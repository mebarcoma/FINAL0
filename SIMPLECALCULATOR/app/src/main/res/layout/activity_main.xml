<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- DISPLAY -->
    <TextView
        android:id="@+id/textViewResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="60sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:textAlignment="textEnd"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ROW: Clear, Back, Divide -->
    <LinearLayout
        android:id="@+id/topRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/textViewResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="C"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF0000"
            android:onClick="buttonClear"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#333333"
            android:onClick="buttonBack"
            android:text="⌫"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnDivide"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="/"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF0000"
            android:onClick="buttonDivide"/>
    </LinearLayout>

    <!-- NUMBERS + OPERATORS GRID -->
    <GridLayout
        android:id="@+id/gridButtons"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:columnCount="4"
        android:rowCount="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topRow"
        app:layout_constraintVertical_bias="1.0">

        <!-- Row 1 -->

        <Button
            android:id="@+id/btnSeven"
            android:backgroundTint="#222222"
            android:onClick="buttonSeven"
            android:text="7"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnEight"
            android:backgroundTint="#222222"
            android:onClick="buttonEight"
            android:text="8"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnNine"
            android:backgroundTint="#222222"
            android:onClick="buttonNine"
            android:text="9"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnMultiply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF0000"
            android:onClick="buttonTimes"
            android:text="*"
            android:textColor="#FFFFFF" />

        <!-- Row 2 -->
        <Button
            android:id="@+id/btnFour"
            android:backgroundTint="#222222"
            android:onClick="buttonFour"
            android:text="4"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnFive"
            android:backgroundTint="#222222"
            android:onClick="buttonFive"
            android:text="5"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnSix"
            android:backgroundTint="#222222"
            android:onClick="buttonSix"
            android:text="6"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnMinus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF0000"
            android:onClick="buttonMinus"
            android:text="-"
            android:textColor="#FFFFFF" />

        <!-- Row 3 -->
        <Button
            android:id="@+id/btnOne"
            android:backgroundTint="#222222"
            android:onClick="buttonOne"
            android:text="1"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnTwo"
            android:backgroundTint="#222222"
            android:onClick="buttonTwo"
            android:text="2"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnThree"
            android:backgroundTint="#222222"
            android:onClick="buttonThree"
            android:text="3"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnPlus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF0000"
            android:onClick="buttonPlus"
            android:text="+"
            android:textColor="#FFFFFF" />

        <!-- Row 4 -->

        <Button
            android:id="@+id/btnZero"
            android:layout_row="1"
            android:layout_column="0"
            android:backgroundTint="#222222"
            android:onClick="buttonZero"
            android:text="0"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnPoint"
            android:backgroundTint="#222222"
            android:onClick="buttonPoint"
            android:text="."
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnEquals"
            android:layout_width="wrap_content"
            android:backgroundTint="#FF0000"
            android:onClick="calculate"
            android:text="="
            android:textColor="#FFFFFF" />
        <!-- Empty placeholder for grid alignment -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>